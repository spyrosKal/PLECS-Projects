    Component {
      Type          CScript
      Name          "C-Script"
      Show          off
      Position      [1745, 505]
      Direction     up
      Flipped       off
      LabelPosition south
      Parameter {
        Variable      "DialogGeometry"
        Value         "[723 320 715 516]"
        Show          off
      }
      Parameter {
        Variable      "NumInputs"
        Value         "2"
        Show          off
      }
      Parameter {
        Variable      "NumOutputs"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "NumContStates"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "NumDiscStates"
        Value         "2"
        Show          off
      }
      Parameter {
        Variable      "NumZCSignals"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "DirectFeedthrough"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "Ts"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "TerminalBasedSampleTimes"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "Parameters"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "LangStandard"
        Value         "2"
        Show          off
      }
      Parameter {
        Variable      "GnuExtensions"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "RuntimeCheck"
        Value         "2"
        Show          off
      }
      Parameter {
        Variable      "HighlightLevel"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "Declarations"
        Value         "#define V_TARGET  400.0\n"
"#define T_RAMP    1.0 \n"
"#define TS        1e-4\n"
"\n"
"// --- INPUTS & OUTPUTS ---\n"
"#define V_ACTUAL  InputSignal(0, 1) \n"
"#define ENABLE    InputSignal(0, 0) \n"
"\n"
"#define VDC_REF   OutputSignal(0, 0)\n"
"\n"
"// --- STATES ---\n"
"#define Timer     DiscState(0)\n"
"#define V_Start   DiscState(1)"
        Show          off
      }
      Parameter {
        Variable      "StartFcn"
        Value         "Timer = 0.0;\n"
"V_Start = 0.0;"
        Show          off
      }
      Parameter {
        Variable      "OutputFcn"
        Value         "if (ENABLE > 0.5) {\n"
"    // Calculate how far along the ramp we are (0.0 to 1.0)\n"
"    double factor = Timer / T_RAMP;\n"
"    if (factor > 1.0) factor = 1.0;\n"
"    \n"
"    // Output = Start_Voltage + (Difference * factor)\n"
"    VDC_REF = V_Start + (V_TARGET - V_Start) * factor;\n"
"} \n"
"else {\n"
"    // While OFF, just output the actual measured voltage (so error = 0)\n"
"    VDC_REF = V_ACTUAL;\n"
"}"
        Show          off
      }
      Parameter {
        Variable      "UpdateFcn"
        Value         "if (ENABLE < 0.5) {\n"
"    // While OFF: Keep Timer at 0 and constantly track the precharge voltage"
"\n"
"    Timer = 0.0;\n"
"    V_Start = V_ACTUAL; \n"
"} \n"
"else {\n"
"    // While ON: Advance the timer. V_Start stops updating and is \"latched\""
"\n"
"    if (Timer < T_RAMP) {\n"
"        Timer += TS;\n"
"    }\n"
"}"
        Show          off
      }
      Parameter {
        Variable      "DerivativeFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "TerminateFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "StoreCustomStateFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "RestoreCustomStateFcn"
        Value         ""
        Show          off
      }
    }
